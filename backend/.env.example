# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# --- Database (AWS RDS MySQL). Leave DB_HOST empty to run in-memory (no DB required). ---
DB_HOST=
DB_PORT=3306
DB_NAME=living_twin
DB_USER=admin
DB_PASSWORD=
DB_SSL=true

# --- Simulator / booth loop ---
SIM_INTERVAL_MS=2000
FLEET_SIZE=50
INCIDENT_MIN_GAP_MS=7000
INCIDENT_MAX_GAP_MS=13000
AUTO_APPROVE=true          # booth: auto-approve recovery after a short pause
AUTO_APPROVE_DELAY_MS=3000

# --- Optional live LLM diagnosis (leave empty to use built-in reasoning engine) ---
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
