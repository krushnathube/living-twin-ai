# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# --- Database (AWS RDS MySQL). Leave DB_HOST empty to run in-memory (no DB required). ---
DB_HOST=
DB_PORT=3306
DB_NAME=hm_living_twin_ai
DB_USER=admin
DB_PASSWORD=
DB_SSL=true

# --- Simulator / booth loop ---
SIM_INTERVAL_MS=2000
FLEET_SIZE=50
INCIDENT_MIN_GAP_MS=7000
INCIDENT_MAX_GAP_MS=13000
AUTO_APPROVE=true          # booth: auto-approve recovery after a short pause
AUTO_APPROVE_DELAY_MS=6000

# --- Optional live LLM diagnosis (leave empty to use the built-in reasoning engine) ---
# Paste your Anthropic API key here to have the council generate diagnosis from a live model.
# Confirm the current model string in your Anthropic console; update LLM_MODEL if needed.
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5
